# scrapariga — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Application ────────────────────────────────────────────────────────────

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Runtime environment: development | production
NODE_ENV=development

# ─── DemoProvider ────────────────────────────────────────────────────────────
# Set to a step name to simulate failure on that step (for testing the retry UI).
# Accepted values: login | fetch | download
# Leave blank (or omit) for normal demo execution.
DEMO_FAIL_ON=

# ─── Future Provider Credentials ─────────────────────────────────────────────
# Provider-specific variables will be added here automatically
# when you run each provider for the first time and answer the credential prompts.
# Example:
# ENEL_USERNAME=
# ENEL_PASSWORD=
